---
/**
 * Ambient.astro — the warehouse world around the crates (brief §4).
 * Paper grain, faint shelf/floor lines, a swaying lamp, a drifting paper plane.
 * Decorative and non-interactive; idle motion only, all disabled under reduced
 * motion by the global reset. Ported from hub-inked / hub-taste.
 */
---

<svg class="grain" aria-hidden="true">
  <filter id="grain-n">
    <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch"
    ></feTurbulence>
    <feColorMatrix type="saturate" values="0"></feColorMatrix>
  </filter>
  <rect width="100%" height="100%" filter="url(#grain-n)" opacity="0.32"></rect>
</svg>

<svg class="floor" preserveAspectRatio="none" viewBox="0 0 1000 1000" aria-hidden="true">
  <g stroke="#191512" stroke-width="1" opacity="0.06" fill="none">
    <line x1="0" y1="120" x2="1000" y2="120"></line>
    <line x1="0" y1="440" x2="1000" y2="440"></line>
    <line x1="0" y1="760" x2="1000" y2="760"></line>
    <line x1="250" y1="0" x2="250" y2="1000"></line>
    <line x1="740" y1="0" x2="740" y2="1000"></line>
  </g>
</svg>

<svg class="scatter lamp" width="40" height="120" viewBox="0 0 40 120" aria-hidden="true">
  <g stroke="#191512" stroke-width="1.6" fill="none">
    <line x1="20" y1="0" x2="20" y2="64"></line>
    <path d="M6 64 Q20 90 34 64 Z" fill="#EFE9DA"></path>
    <circle cx="20" cy="76" r="4" fill="#191512" opacity=".5"></circle>
  </g>
</svg>

<svg class="scatter plane" width="58" height="40" viewBox="0 0 58 40" aria-hidden="true">
  <g stroke="#191512" stroke-width="1.6" fill="none">
    <path d="M2 6 L56 2 L24 38 L20 22 Z"></path>
    <path d="M2 6 L20 22 L56 2"></path>
  </g>
</svg>

<style>
  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.45;
    z-index: 1;
  }
  .floor {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.5;
  }
  .scatter {
    position: absolute;
    z-index: 1;
    color: var(--ink);
    opacity: 0.5;
    pointer-events: none;
  }
  .lamp {
    top: -6px;
    left: 50%;
    transform-origin: top center;
    animation: sway 5.5s ease-in-out infinite;
  }
  @keyframes sway {
    0%,
    100% {
      transform: rotate(-2.5deg);
    }
    50% {
      transform: rotate(2.5deg);
    }
  }
  .plane {
    bottom: 120px;
    right: -14px;
    animation: bob 6s ease-in-out infinite;
  }
  @keyframes bob {
    0%,
    100% {
      transform: translateY(0) rotate(-6deg);
    }
    50% {
      transform: translateY(-10px) rotate(-2deg);
    }
  }
  @media (max-width: 720px) {
    .lamp,
    .plane {
      display: none;
    }
  }
</style>
