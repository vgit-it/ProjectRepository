---
/**
 * Seal.astro — the sealed/gated stamp (brief §5, §7, §9).
 * The ONLY place the accent red appears. The rough rings are ink-drawn (red) by
 * the crate orchestrator (it finds [data-seal]); the label text is static.
 */
interface Props {
  /** small code shown under the SEALED word, e.g. the vault number */
  code?: string;
}
const { code = "" } = Astro.props;
---

<svg class="seal" data-seal viewBox="0 0 60 60" aria-label="sealed — passcode required" role="img">
  <text class="txt" x="30" y="27" text-anchor="middle" font-size="9">SEALED</text>
  {
    code && (
      <text class="txt" x="30" y="41" text-anchor="middle" font-size="14">
        {code}
      </text>
    )
  }
</svg>

<style>
  .seal {
    position: absolute;
    top: -14px;
    right: -10px;
    width: 58px;
    height: 58px;
    transform: rotate(11deg) translateZ(60px);
    z-index: 6;
    color: var(--accent);
    overflow: visible;
    pointer-events: none;
  }
  .seal .txt {
    fill: var(--accent);
    font-family: var(--font-display);
    font-weight: 700;
  }
</style>
