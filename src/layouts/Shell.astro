---
/**
 * Shell.astro — the constant shell (brief §2).
 *
 * Carries the site's constant signature around every page: <head>, the mark
 * (= home, always present), a back control, and where page transitions will
 * live. Each project "room" themes its interior freely inside this shell.
 */
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** show the back control (rooms yes, hub no) */
  back?: boolean;
}

const {
  title = "The Warehouse",
  description = "A personal site to document and store my projects.",
  back = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : base + "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${home}favicon.svg`} />

    {/* TODO: self-host fonts under /public/fonts (brief §7). Linked for now. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Kalam:wght@400;700&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {/* The mark — home, always present (brief §3 navigation). */}
    <header class="shell-mark">
      <a href={home} class="mark" aria-label="The Warehouse — home">
        <svg class="glyph" viewBox="0 0 48 48" aria-hidden="true">
          <g stroke="currentColor" stroke-width="2" fill="none" stroke-linejoin="round">
            <path d="M10 38 L10 10 L24 24 L38 10 L38 38"></path>
          </g>
        </svg>
        <span class="mark-words">
          <span class="name">[ your mark ]</span>
          <span class="sub">the warehouse</span>
        </span>
      </a>
      {
        back ? (
          <a href={home} class="back">
            ← back
          </a>
        ) : (
          <span class="hi">say hi ✎</span>
        )
      }
    </header>

    <main>
      <slot />
    </main>

    <footer class="shell-foot">
      <small>The Warehouse · scaffolding (Pass 1)</small>
    </footer>

    <style>
      .shell-mark {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        max-width: 1180px;
        margin-inline: auto;
        padding: var(--space-lg) var(--space-md) 0;
      }
      .mark {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: var(--ink);
      }
      .mark .glyph {
        width: 46px;
        height: 46px;
      }
      .mark .name {
        display: block;
        font-family: var(--font-display);
        font-size: 30px;
        line-height: 0.9;
        font-weight: 700;
      }
      .mark .sub {
        display: block;
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-top: 3px;
      }
      .back,
      .hi {
        font-family: var(--font-display);
        font-size: 20px;
        text-decoration: none;
        color: var(--ink-soft);
      }
      main {
        position: relative;
        z-index: 2;
        padding: 0 var(--space-md) var(--space-xl);
        max-width: 1180px;
        margin-inline: auto;
      }
      .shell-foot {
        position: relative;
        z-index: 2;
        padding: var(--space-lg);
        color: var(--ink-40);
        text-align: center;
      }
    </style>
  </body>
</html>
