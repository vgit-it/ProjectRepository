---
/**
 * projects/[...slug].astro — a project "room" (brief §2, §3).
 *
 * One page per project from the collection, inside the constant Shell. Gated
 * projects keep the room body hidden behind the passcode gate (reveal mode);
 * once unlocked (this session) the body shows. Themed interiors per project type
 * arrive as each real project is built.
 */
import { getCollection, render } from "astro:content";
import Shell from "@layouts/Shell.astro";
import Seal from "@components/Seal.astro";
import PasscodePrompt from "@components/PasscodePrompt.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, label, category, gated, passcode, code } = project.data;
---

<Shell title={`${title} — The Warehouse`} description={summary} back>
  <article
    class="room"
    data-slug={project.id}
    data-gated={gated ? "1" : undefined}
    data-code={passcode}
  >
    <header class="room-head">
      <span class="cat">{label ?? category.toLowerCase()}</span>
      <h1>{title}</h1>
      {summary && <p class="lede">{summary}</p>}
      {gated && <Seal code={code} />}
    </header>

    {
      gated && (
        <div class="gate" data-gate hidden>
          <p>This room is sealed.</p>
          <button type="button" data-gate-open>
            knock for the code ✎
          </button>
        </div>
      )
    }

    <div class="room-body" data-room hidden={gated ? true : undefined}>
      <Content />
    </div>
  </article>

  {gated && <PasscodePrompt />}
</Shell>

<style>
  .room {
    position: relative;
    max-width: 70ch;
    margin-inline: auto;
    padding-block: var(--space-lg);
  }
  .room-head {
    position: relative;
    margin-bottom: var(--space-lg);
  }
  .cat {
    font-size: var(--step--1);
    color: var(--ink-soft);
    text-transform: lowercase;
    letter-spacing: 0.06em;
  }
  .lede {
    color: var(--ink-soft);
    margin-top: var(--space-sm);
  }
  .gate {
    border: 1.5px dashed var(--ink-40);
    padding: var(--space-lg);
    text-align: center;
    border-radius: 6px;
  }
  .gate button {
    margin-top: var(--space-sm);
    font-family: var(--font-display);
    font-size: var(--step-1);
    background: var(--ink);
    color: var(--paper);
    border: none;
    padding: 7px 18px;
    cursor: pointer;
  }
  .room-body :global(p) {
    margin-block: var(--space-sm);
  }
</style>

<script>
  const room = document.querySelector<HTMLElement>(".room[data-gated]");
  if (room) {
    const slug = room.dataset.slug ?? "";
    const code = room.dataset.code ?? "";
    const gate = room.querySelector<HTMLElement>("[data-gate]");
    const body = room.querySelector<HTMLElement>("[data-room]");
    const openBtn = room.querySelector<HTMLElement>("[data-gate-open]");

    function reveal() {
      body?.removeAttribute("hidden");
      if (gate) gate.hidden = true;
    }

    if (sessionStorage.getItem("wh:" + slug) === "1") {
      reveal();
    } else if (gate) {
      gate.hidden = false;
    }

    openBtn?.addEventListener("click", () => {
      window.dispatchEvent(
        new CustomEvent("warehouse:gate", {
          detail: { title: document.title, code, slug, mode: "reveal" },
        }),
      );
    });

    window.addEventListener("warehouse:unlocked", (e) => {
      if ((e as CustomEvent).detail?.slug === slug) reveal();
    });
  }
</script>
