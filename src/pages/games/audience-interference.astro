---
/**
 * audience-interference.astro — playable route for the Audience Interference game.
 *
 * You are a spectator in the stands: hop around the ground with the bottom-left D-pad (or
 * arrow keys · WASD — the zoomed follow-camera pans with you), then hold the bottom-right
 * throw button and deflect it like a joystick to place the landing reticle within reach;
 * release to launch the item, dazing the team you're sabotaging so the side you back wins.
 *
 * DEV PALETTE EXCEPTION (temporary, scoped to this page + src/games/audience-interference/
 * only): CLAUDE.md rule 4 reserves color for the Seal stamp and keeps everything else
 * B&W. This game's render/* modules AND its HUD/controls use real gameplay colors
 * deliberately, for build/iteration clarity — confirmed with the project owner. This
 * page stays unlisted from the public hub (no src/content/projects/ entry) until a
 * later monochrome/ink reskin pass makes it presentable site-wide.
 *
 * Full-bleed stage: Shell.astro's <main> caps width at 1180px (by design, rule 1 — not
 * edited here). `.game-breakout` is a page-scoped escape, not a Shell change.
 */
import Shell from "@layouts/Shell.astro";
---

<Shell title="Audience Interference — The Warehouse" back>
  <div class="game-breakout">
    <div class="game-stage" id="game-stage">
      <canvas id="match-canvas"></canvas>

      <div class="ai-hud" id="ai-hud">
        <div class="ai-score">
          <span class="ai-team ai-home" data-backed>HOME</span>
          <span id="ai-score-num">0 – 0</span>
          <span class="ai-team ai-away">AWAY</span>
        </div>
        <div class="ai-topright">
          <div class="ai-clock">
            <span id="ai-phase">FIRST HALF</span> · <span id="ai-time">0:00</span>
          </div>
          <button
            type="button"
            class="ai-fullscreen"
            id="ai-fullscreen"
            aria-label="Toggle fullscreen"
            title="Fullscreen">⛶</button
          >
        </div>
      </div>

      <div class="ai-rotate-hint" id="ai-rotate-hint">Rotate your device to landscape</div>

      <div class="ai-controls" id="ai-controls"></div>

      <div class="ai-result" id="ai-result" hidden>
        <p class="ai-result-title" id="ai-result-title">FULL TIME</p>
        <p class="ai-result-sub" id="ai-result-sub"></p>
        <button type="button" class="ai-replay" id="ai-replay">Play again</button>
      </div>
    </div>
  </div>
</Shell>

<style>
  .game-breakout {
    margin-inline: calc(50% - 50vw);
    width: 100vw;
    padding-block: var(--space-md);
    display: flex;
    justify-content: center;
  }
  .game-stage {
    position: relative;
    width: 100%;
    max-width: 1400px;
    aspect-ratio: 116 / 80;
    touch-action: none;
    user-select: none;
  }
  /* Fill-viewport mode: works on every browser via fixed positioning; the
     Fullscreen API + orientation lock are layered on in JS as enhancement. */
  .game-stage.is-maximized {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    max-width: none;
    aspect-ratio: auto;
    z-index: 9999;
    background: #000;
  }
  canvas {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 6px;
  }
  .game-stage.is-maximized canvas {
    border-radius: 0;
  }

  /* ---- HUD ---- */
  .ai-hud {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 0.6rem 0.9rem;
    color: #f5f5f0;
    font-family: var(--font-body, system-ui), sans-serif;
    pointer-events: none;
  }
  .ai-score {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-weight: 700;
    font-size: clamp(1rem, 3vw, 1.4rem);
    background: rgba(0, 0, 0, 0.4);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .ai-team {
    font-size: 0.7em;
    opacity: 0.85;
  }
  .ai-home {
    color: #7ab6ff;
  }
  .ai-away {
    color: #f0cf5a;
  }
  .ai-team[data-backed]::after {
    content: " ★";
    color: #fff;
  }
  .ai-topright {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .ai-clock {
    background: rgba(0, 0, 0, 0.4);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: clamp(0.75rem, 2.4vw, 1rem);
  }
  .ai-fullscreen {
    pointer-events: auto;
    cursor: pointer;
    background: rgba(0, 0, 0, 0.4);
    color: #f5f5f0;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    width: 2.1rem;
    height: 2.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0;
  }
  .ai-fullscreen:active {
    transform: scale(0.94);
  }

  /* portrait nudge: only while maximized and the orientation lock didn't take */
  .ai-rotate-hint {
    display: none;
  }
  .game-stage.is-maximized .ai-rotate-hint {
    display: none;
  }
  @media (orientation: portrait) {
    .game-stage.is-maximized .ai-rotate-hint {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      background: rgba(0, 0, 0, 0.82);
      color: #f5f5f0;
      font-family: var(--font-body, system-ui), sans-serif;
      font-weight: 700;
      font-size: clamp(1.1rem, 5vw, 1.6rem);
    }
  }

  /* ---- controls ---- */
  .ai-controls {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  /* D-pad, bottom-left: a +-shaped cluster of four hop buttons. Directions are
     screen-relative, so the button you press is the way you move. */
  :global(.ai-dpad) {
    position: absolute;
    inset-block-end: 5%;
    inset-inline-start: 4%;
    width: clamp(132px, 33vw, 186px);
    aspect-ratio: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 4px;
    pointer-events: none;
  }
  :global(.ai-dpad button) {
    border-radius: 14px;
    background: rgba(120, 200, 220, 0.2);
    border: 2px solid rgba(120, 200, 220, 0.55);
    color: #eafaff;
    font-size: clamp(0.9rem, 2.8vw, 1.4rem);
    line-height: 1;
    pointer-events: auto;
    cursor: pointer;
    touch-action: none;
    padding: 0;
  }
  :global(.ai-dpad-up) {
    grid-area: 1 / 2 / 2 / 3;
  }
  :global(.ai-dpad-left) {
    grid-area: 2 / 1 / 3 / 2;
  }
  :global(.ai-dpad-right) {
    grid-area: 2 / 3 / 3 / 4;
  }
  :global(.ai-dpad-down) {
    grid-area: 3 / 2 / 4 / 3;
  }
  :global(.ai-dpad button.is-held) {
    background: rgba(120, 200, 220, 0.45);
    transform: scale(0.92);
  }

  /* Throw joystick, bottom-right: hold to aim, deflect the knob to place the reticle,
     release to launch. */
  :global(.ai-throw) {
    position: absolute;
    inset-block-end: 5%;
    inset-inline-end: 4%;
    width: clamp(84px, 20vw, 128px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(255, 61, 181, 0.16);
    border: 2px solid rgba(255, 61, 181, 0.6);
    pointer-events: auto;
    cursor: pointer;
    touch-action: none;
    padding: 0;
  }
  :global(.ai-throw.is-held) {
    background: rgba(255, 61, 181, 0.28);
  }
  :global(.ai-throw-knob) {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    transform: translate(-50%, -50%);
    width: 42%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(255, 61, 181, 0.55);
    border: 2px solid rgba(255, 220, 240, 0.8);
    pointer-events: none;
  }
  :global(.ai-items) {
    position: absolute;
    inset-block-end: 6%;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    pointer-events: auto;
  }
  :global(.ai-item) {
    width: clamp(40px, 11vw, 58px);
    aspect-ratio: 1;
    border-radius: 12px;
    border: 2px solid rgba(255, 255, 255, 0.35);
    background: rgba(0, 0, 0, 0.45);
    color: #f5f5f0;
    font-weight: 700;
    font-size: clamp(0.9rem, 2.6vw, 1.2rem);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  :global(.ai-item.is-active) {
    border-color: #ff3db5;
    box-shadow: 0 0 0 2px rgba(255, 61, 181, 0.5);
  }
  /* cooldown shade: --cd is 0 (cooling) .. 1 (ready) */
  :global(.ai-item)::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    transform-origin: bottom;
    transform: scaleY(calc(1 - var(--cd, 1)));
    transition: transform 0.1s linear;
    pointer-events: none;
  }

  /* ---- result banner ---- */
  .ai-result[hidden] {
    display: none;
  }
  .ai-result {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    text-align: center;
    border-radius: 6px;
  }
  .ai-result-title {
    font-size: clamp(1.8rem, 7vw, 3.5rem);
    font-weight: 800;
    margin: 0;
  }
  .ai-result-sub {
    font-size: clamp(1rem, 3.5vw, 1.6rem);
    margin: 0;
  }
  .ai-replay {
    margin-block-start: 0.8rem;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    border: 3px solid rgba(255, 255, 255, 0.7);
    background: rgba(120, 200, 220, 0.9);
    color: #10222b;
    font-weight: 800;
    font-size: clamp(1rem, 3vw, 1.3rem);
    cursor: pointer;
  }
  .ai-replay:active {
    transform: scale(0.96);
  }
</style>

<script>
  import { boot, type HudState } from "@games/audience-interference";

  const canvas = document.querySelector<HTMLCanvasElement>("#match-canvas");
  const controlsRoot = document.querySelector<HTMLElement>("#ai-controls");
  const scoreNum = document.querySelector<HTMLElement>("#ai-score-num");
  const phaseEl = document.querySelector<HTMLElement>("#ai-phase");
  const timeEl = document.querySelector<HTMLElement>("#ai-time");
  const result = document.querySelector<HTMLElement>("#ai-result");
  const resultTitle = document.querySelector<HTMLElement>("#ai-result-title");
  const resultSub = document.querySelector<HTMLElement>("#ai-result-sub");
  const replayBtn = document.querySelector<HTMLButtonElement>("#ai-replay");

  function onHud(hud: HudState): void {
    if (scoreNum) scoreNum.textContent = `${hud.home} – ${hud.away}`;
    if (phaseEl) phaseEl.textContent = hud.phase.replace(/_/g, " ");
    if (timeEl) timeEl.textContent = hud.clock;

    for (const [item, frac] of Object.entries(hud.cooldowns)) {
      const el = controlsRoot?.querySelector<HTMLElement>(`.ai-item[data-item="${item}"]`);
      el?.style.setProperty("--cd", String(frac));
    }

    if (hud.outcome !== "playing" && result?.hidden) {
      result.hidden = false;
      if (resultTitle) {
        resultTitle.textContent =
          hud.outcome === "won" ? "YOU WIN" : hud.outcome === "lost" ? "YOU LOSE" : "DRAW";
      }
      if (resultSub) {
        resultSub.textContent = `Final: ${hud.home} – ${hud.away} · you backed ${hud.backedTeam.toUpperCase()}`;
      }
    }
  }

  if (canvas && controlsRoot) {
    const handle = boot(canvas, { controlsRoot, onHud });
    replayBtn?.addEventListener("click", () => {
      handle.restart();
      if (result) result.hidden = true;
    });
  }

  // ---- fullscreen / fill-viewport toggle ----
  // CSS .is-maximized fills the viewport everywhere; the Fullscreen API and
  // orientation lock are best-effort enhancements that no-op where unsupported
  // (e.g. iOS Safari on non-video elements). The canvas's ResizeObserver in the
  // engine handles the resulting resize, so nothing else needs to change here.
  const stage = document.querySelector<HTMLElement>("#game-stage");
  const fsBtn = document.querySelector<HTMLButtonElement>("#ai-fullscreen");

  function lockLandscape(): void {
    const orientation = screen.orientation as
      | (ScreenOrientation & { lock?: (o: string) => Promise<void> })
      | undefined;
    orientation?.lock?.("landscape").catch(() => {});
  }
  function unlockLandscape(): void {
    try {
      screen.orientation?.unlock?.();
    } catch {
      /* no-op where unsupported */
    }
  }

  function enterMaximized(): void {
    stage?.classList.add("is-maximized");
    stage?.requestFullscreen?.().catch(() => {});
    lockLandscape();
  }
  function exitMaximized(): void {
    stage?.classList.remove("is-maximized");
    if (document.fullscreenElement) document.exitFullscreen?.().catch(() => {});
    unlockLandscape();
  }

  fsBtn?.addEventListener("click", () => {
    if (stage?.classList.contains("is-maximized")) exitMaximized();
    else enterMaximized();
  });

  // Keep state in sync when the user exits fullscreen via Esc / back gesture.
  document.addEventListener("fullscreenchange", () => {
    if (!document.fullscreenElement && stage?.classList.contains("is-maximized")) {
      stage.classList.remove("is-maximized");
      unlockLandscape();
    }
  });
</script>
