---
/**
 * index.astro — the Hub (brief §3, §4).
 *
 * The real hub, migrated from hub-inked / hub-taste: a bento wall of 3D crates
 * (Crate.astro) drawn through the line signature, inked filter tags, the ambient
 * warehouse world, and the passcode gate — all derived from the projects
 * collection so adding a crate is a content change, not a code change.
 */
import { getCollection } from "astro:content";
import Shell from "@layouts/Shell.astro";
import Crate from "@components/Crate.astro";
import Ambient from "@components/Ambient.astro";
import PasscodePrompt from "@components/PasscodePrompt.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const CAT_KEY: Record<string, string> = { Games: "game", Sketch: "sketch", UX: "ux", AI: "ai" };

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const tags = [
  { key: "all", label: "All" },
  { key: "game", label: "Games" },
  { key: "sketch", label: "Sketch" },
  { key: "ux", label: "UX" },
  { key: "ai", label: "AI" },
];
---

<Shell title="The Warehouse">
  <Ambient />

  <section class="heading">
    <h1>Boxes of things<br />I've been making.</h1>
    <p>Open a crate. Some are sealed — knock for the code.</p>
  </section>

  <nav class="tags" id="tags" aria-label="filter projects">
    {
      tags.map((t) => (
        <button class="tag" data-cat={t.key} data-on={t.key === "all" ? "1" : "0"}>
          <span>{t.label}</span>
          <svg class="uline" aria-hidden="true" />
        </button>
      ))
    }
  </nav>

  <main class="grid" id="grid">
    {
      projects.map((p) => (
        <Crate
          href={`${base}/projects/${p.id}`}
          slug={p.id}
          title={p.data.title}
          cat={CAT_KEY[p.data.category] ?? "ai"}
          catLabel={p.data.label ?? p.data.category.toLowerCase()}
          icon={p.data.icon}
          cols={p.data.cols}
          rows={p.data.rows}
          tilt={p.data.tilt}
          jitter={p.data.jitter}
          gated={p.data.gated}
          poster={p.data.poster}
          code={p.data.code}
        />
      ))
    }
  </main>

  <p class="footnote">↑ every line built up + uneven ends — same hand as the sketches ✎</p>

  <PasscodePrompt />
</Shell>

<style>
  .heading {
    margin: 30px 0 6px;
  }
  .heading h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 7vw, 60px);
    line-height: 0.96;
    margin: 0;
  }
  .heading p {
    font-size: 14px;
    color: var(--ink-soft);
    max-width: 46ch;
    margin: 10px 0 0;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin: 26px 0 8px;
  }
  .tag {
    position: relative;
    font-family: var(--font-display);
    font-size: 15px;
    cursor: pointer;
    padding: 5px 14px 12px;
    border: none;
    background: transparent;
    color: var(--ink-soft);
    transition: color 0.2s;
  }
  .tag > span {
    position: relative;
    z-index: 1;
  }
  .tag .uline {
    position: absolute;
    left: 6px;
    right: 6px;
    bottom: 2px;
    height: 10px;
    overflow: visible;
    color: var(--ink);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .tag:hover {
    color: var(--ink);
  }
  .tag[data-on="1"] {
    color: var(--ink);
  }
  .tag[data-on="1"] .uline,
  .tag:hover .uline {
    opacity: 1;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 118px;
    gap: 20px;
    margin-top: 18px;
  }

  .footnote {
    font-family: var(--font-display);
    font-size: 19px;
    color: var(--ink-soft);
    margin-top: 46px;
    text-align: center;
    transform: rotate(-0.6deg);
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 108px;
      gap: 14px;
    }
  }
</style>

<script>
  import { draw, size } from "@lib/ink";

  // inked filter-tag underlines
  const tags = [...document.querySelectorAll<HTMLElement>(".tag")];
  function drawTagLines() {
    tags.forEach((t) => {
      const u = t.querySelector<SVGSVGElement>(".uline");
      if (!u) return;
      const w = t.clientWidth - 12;
      size(u, w, 10);
      draw(u, (k) => k.line(2, 5, w - 2, 4));
    });
  }

  // filter: dim crates that don't match (gated crates always stay visible)
  const crates = [...document.querySelectorAll<HTMLElement>(".crate")];
  tags.forEach((t) =>
    t.addEventListener("click", () => {
      tags.forEach((x) => (x.dataset.on = "0"));
      t.dataset.on = "1";
      const c = t.dataset.cat;
      crates.forEach((cr) => {
        const show = c === "all" || cr.dataset.cat === c || cr.dataset.locked === "1";
        cr.classList.toggle("dim", !show);
      });
    }),
  );

  let rt: number;
  window.addEventListener("resize", () => {
    clearTimeout(rt);
    rt = window.setTimeout(drawTagLines, 160);
  });
  window.addEventListener("load", drawTagLines);
  document.fonts?.ready.then(drawTagLines);
</script>
